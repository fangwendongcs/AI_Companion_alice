# Server
PORT=3000
# local: developer machine, demo: private preview, production: public deployment
DEPLOYMENT_MODE=local
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_LOCALHOST=true
REQUIRE_API_AUTH=false
API_AUTH_TOKEN=replace_with_private_token
JSON_BODY_LIMIT=1mb
UPLOAD_BODY_LIMIT=80mb
AVATAR_UPLOAD_MAX_MB=80
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=240
RATE_LIMIT_SENSITIVE_MAX_REQUESTS=60
UPSTREAM_TIMEOUT_MS=45000
N8N_TIMEOUT_MS=8000

# LLM / OpenAI-compatible providers
# Default browser-visible provider is stub, so these keys are optional for local demo.
OPENAI_API_KEY=replace_with_your_key
OPENAI_BASE_URL=https://api.openai.com/v1
QWEN_API_KEY=replace_with_your_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DEEPSEEK_API_KEY=replace_with_your_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
CUSTOM_API_KEY=replace_with_your_key
CUSTOM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=replace_with_your_key

# TTS
MINIMAX_API_KEY=replace_with_your_key
MINIMAX_BASE_URL=https://api.minimax.io/v1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
MINIMAX_TTS_MODEL=speech-2.8-hd

# Optional workflow / future integrations
# n8n is only called by the backend when /api/dialogue options.useWorkflow=true.
N8N_WEBHOOK_URL=https://example.invalid/webhook
N8N_WEBHOOK_SECRET=replace_with_your_secret
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=replace_with_your_key
QDRANT_COLLECTION=example_collection
PHOENIX_ENDPOINT=http://localhost:6006
PHOENIX_API_KEY=replace_with_your_key
RAG_PROVIDER=example_provider
RAG_COLLECTION=example_collection
MEMORY_STORE=example_store
AGENT_PROVIDER=example_provider
AGENT_MODEL=example_model
